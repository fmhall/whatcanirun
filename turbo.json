{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*", "**/tsconfig.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "//#__lint__": {
      "dependsOn": ["//#__check__"]
    },
    "//#__format__": {},
    "//#__check__": {
      "dependsOn": [
        "^typecheck"
      ]
    }
  }
}
