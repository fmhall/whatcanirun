{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*", "**/tsconfig.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "BETTER_AUTH_URL",
        "BETTER_AUTH_SECRET",
        "AUTH_GITHUB_ID",
        "AUTH_GITHUB_SECRET",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "DATABASE_URL",
        "MPP_SECRET_KEY"
      ],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "//#__lint__": {
      "dependsOn": ["//#__check__"]
    },
    "//#__format__": {},
    "//#__check__": {
      "dependsOn": [
        "^typecheck"
      ]
    }
  }
}
